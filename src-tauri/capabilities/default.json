{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-canvas-capabilities",
  "description": "Exposes file execution, disk persistence, and dialogue capabilities specifically to the workspace window.",
  "windows": [
    "main"
  ],
  "platforms": [
    "linux",
    "macOS",
    "windows"
  ],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "store:allow-get-store",
    "store:allow-get",
    "store:allow-set",
    "store:allow-delete"
  ]
}
