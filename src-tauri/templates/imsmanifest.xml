<?xml version="1.0" encoding="UTF-8"?>
<!-- imsmanifest.xml - Validated template file -->
<manifest identifier="MANIFEST-{{PACKAGE_UUID}}" version="1.0"
          xmlns="http://www.imsproject.org/xsd/imscp_rootv1p1p2"
          xmlns:adlcp="http://www.adlnet.org/xsd/adlcp_rootv1p2"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.imsproject.org/xsd/imscp_rootv1p1p2 imscp_rootv1p1p2.xsd
                              http://www.adlnet.org/xsd/adlcp_rootv1p2 adlcp_rootv1p2.xsd">
  <metadata>
    <schema>ADL SCORM</schema>
    <schemaversion>1.2</schemaversion> <!-- SCORM version specification -->
  </metadata>
  <organizations default="ORG-CANVAS-CATALOG">
    <organization identifier="ORG-CANVAS-CATALOG">
      <title>{{CANVAS_DOCUMENT_NAME}}</title>
      <item identifier="ITEM-CANVAS-SCO-1" identifierref="RES-CANVAS-SCO-1" isvisible="true">
        <title>{{CANVAS_SLIDE_NAME}}</title>
        <adlcp:masteryscore>80</adlcp:masteryscore> <!-- Minimum grade threshold required to pass -->
      </item>
    </organization>
  </organizations>
  <resources>
    <!-- Defines the entry launch file alongside dependent static assets -->
    <resource identifier="RES-CANVAS-SCO-1" type="webcontent" adlcp:scormtype="sco" href="index.html">
      <file href="index.html"/>
      <file href="assets/vendor-bundle.js"/>
      <file href="assets/main-build.css"/>
    </resource>
  </resources>
</manifest>
